# --- Aplicação ---
APP_ENV=development
SECRET_KEY=changeme

# --- Banco de dados ---
DATABASE_URL=postgresql+asyncpg://contextflow:contextflow@localhost:5432/contextflow

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=changeme
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Provedor de IA ---
# Opções: "ollama" (padrão, local, gratuito) ou "openai" (pago, opcional)
AI_PROVIDER=ollama

# Usado somente se AI_PROVIDER=ollama
# llama3.2:1b é rápido mas fraco demais pra seguir instruções de RAG (testado e descartado);
# 3b já responde de forma confiável usando o contexto recuperado.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Usado somente se AI_PROVIDER=openai (nunca commitar uma chave real)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Dimensão do vetor no pgvector: 768 pra nomic-embed-text (Ollama), 1536 pra
# text-embedding-3-small (OpenAI). Trocar de provedor com dimensão diferente exige nova migration.
EMBEDDING_DIM=768
